# Django Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to version control!

# ============================================================================
# Django Core Settings
# ============================================================================

# SECURITY WARNING: Generate a new SECRET_KEY for production!
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-REPLACE-WITH-SECURE-KEY-min-50-chars

# Debug mode (MUST be False in production)
DEBUG=True

# ============================================================================
# Database Configuration
# ============================================================================

# Local development (SQLite) - Comment out for PostgreSQL
# DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (Neon/Railway) - Uncomment and fill in for production
# DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# ============================================================================
# Admin User Configuration (for create_admin.py script)
# ============================================================================

# These credentials will be used to create the superuser
# SECURITY: Use strong passwords (min 12 chars, mixed case, numbers, symbols)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@learnplatform.dev
ADMIN_PASSWORD=ChangeMe123!SecurePassword

# ============================================================================
# Django Admin URL (customize for security in production)
# ============================================================================

DJANGO_ADMIN_URL=admin/

# ============================================================================
# Deployment Configuration
# ============================================================================

# Environment identifier (local, preproduction, production)
RAILWAY_ENVIRONMENT=local
ENVIRONMENT=development

# Railway Static URL (if using Railway)
# RAILWAY_STATIC_URL=https://your-app.railway.app

# ============================================================================
# CORS & CSRF Configuration (Production)
# ============================================================================

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Additional CORS allowed origins (comma-separated, production only)
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-domain.com

# CSRF trusted origins (comma-separated, production only)
# CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app,https://your-backend.railway.app