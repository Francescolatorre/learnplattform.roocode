#!/bin/bash
#
# Git Pre-Commit Hook
#
# Prevents commits with secrets or quality issues.
# Install with: git config core.hooksPath .githooks

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}Running pre-commit checks...${NC}"

# Check for secrets in staged files
echo -n "Checking for secrets... "
if git diff --cached --name-only | xargs -I {} grep -lE "(password|secret|key)\s*=\s*[\"'][^\"']{8,}[\"']" {} 2>/dev/null; then
    echo -e "${RED}❌${NC}"
    echo -e "${RED}ERROR: Potential secret found in staged changes!${NC}"
    echo "Please remove hardcoded credentials before committing."
    echo ""
    echo "Tip: Use environment variables instead:"
    echo "  ❌ password = 'MySecret123'"
    echo "  ✅ password = os.getenv('ADMIN_PASSWORD')"
    exit 1
fi
echo -e "${GREEN}✅${NC}"

# Check for .env files
echo -n "Checking for .env files... "
if git diff --cached --name-only | grep -E "^(backend/|frontend/)?\.env$" >/dev/null; then
    echo -e "${RED}❌${NC}"
    echo -e "${RED}ERROR: Attempting to commit .env file!${NC}"
    echo "Environment files should not be committed."
    echo "If you need to commit a template, use .env.example instead."
    exit 1
fi
echo -e "${GREEN}✅${NC}"

# Check for large files (>5MB)
echo -n "Checking for large files... "
MAX_SIZE=5242880  # 5MB in bytes
LARGE_FILES=$(git diff --cached --name-only | while read file; do
    if [ -f "$file" ]; then
        size=$(wc -c < "$file")
        if [ "$size" -gt "$MAX_SIZE" ]; then
            echo "$file ($(($size / 1024 / 1024))MB)"
        fi
    fi
done)

if [ -n "$LARGE_FILES" ]; then
    echo -e "${YELLOW}⚠️${NC}"
    echo -e "${YELLOW}WARNING: Large files detected:${NC}"
    echo "$LARGE_FILES"
    echo ""
    read -p "Continue anyway? (y/N): " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
else
    echo -e "${GREEN}✅${NC}"
fi

# Check for console.log in TypeScript/JavaScript (warning only)
echo -n "Checking for console.log... "
if git diff --cached --name-only | grep -E "\.(ts|tsx|js|jsx)$" | xargs grep -n "console\.(log|debug|info)" 2>/dev/null; then
    echo -e "${YELLOW}⚠️${NC}"
    echo -e "${YELLOW}WARNING: console.log statements found${NC}"
    echo "Consider removing or using proper logging in production code."
    echo ""
    read -p "Continue anyway? (y/N): " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
else
    echo -e "${GREEN}✅${NC}"
fi

echo -e "${GREEN}✅ Pre-commit checks passed!${NC}"
exit 0
